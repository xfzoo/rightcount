{
  "manifest_version": 3,
  "name": "RightCount",
  "version": "1.0.0",
  "description": "Instantly show a lightweight count bubble when you right-click selected text on a web page.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "placement-core.js",
        "content.js"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ]
}
